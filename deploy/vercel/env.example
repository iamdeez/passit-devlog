# ──────────────────────────────────────────────────
# Passit Frontend — Vercel 환경변수 (Demo Mode)
#
# Vercel 대시보드 > Settings > Environment Variables 에
# 아래 항목을 추가하면 mock 데이터로 동작하는 demo 배포가 됩니다.
# ──────────────────────────────────────────────────

# demo 모드 활성화 (필수)
# "mock"으로 설정하면 실제 백엔드 없이 src/demo/ 데이터로 동작
REACT_APP_API_MODE=mock

# demo 모드 플래그 (필수)
REACT_APP_DEMO_MODE=true

# CloudFront URL (demo 모드에서는 사용되지 않음 — 빈 값 허용)
REACT_APP_CLOUDFRONT_URL=

# 서비스별 API URL (demo 모드에서는 무시됨 — 빈 값 허용)
REACT_APP_ACCOUNT_API_URL=
REACT_APP_TICKET_API_URL=
REACT_APP_TRADE_API_URL=
REACT_APP_CHAT_API_URL=
REACT_APP_CS_API_URL=
