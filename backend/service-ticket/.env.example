# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=passit_db
DB_USER=passit_user
DB_PASSWORD=passit_password

# Application Configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8082

# JWT (서비스 간 토큰 검증 — 전 서비스 동일 값 사용)
JWT_SECRET=local-dev-only-jwt-secret-change-via-env-in-production

# AWS / S3 (이미지 업로드 — 로컬은 LocalStack)
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=passit-bucket

# SNS/SQS (거래 이벤트 연동 — 로컬은 비활성/LocalStack)
SNS_TICKET_EVENTS_TOPIC_ARN=arn:aws:sns:ap-northeast-2:000000000000:ticket-events
SQS_TICKET_DEAL_EVENTS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/000000000000/ticket-deal-events
